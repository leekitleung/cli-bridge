{
  "name": "cli-bridge",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build-extension": "node ./scripts/build-extension.mjs",
    "lint": "node ./scripts/lint.mjs",
    "remote-review-gate": "node ./scripts/remote-review-gate.mjs --pretty",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --experimental-strip-types --test",
    "start:local-server": "node --experimental-strip-types apps/local-server/src/server.ts",
    "review": "node --experimental-strip-types apps/local-server/src/cli/review.ts"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.8.3"
  }
}
